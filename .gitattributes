# Set default behavior for all files
* text=auto

# Explicitly set line endings for specific file types
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.xml text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (don't touch line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.pdb binary
*.ttf binary
*.woff binary
*.woff2 binary
*.mp4 binary
*.wav binary
*.m4a binary
*.mp3 binary
*.flac binary